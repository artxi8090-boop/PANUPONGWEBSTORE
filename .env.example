# Environment Variables for Panupongwebstore
# Copy this file to .env.local and fill in the values

# JWT Secret (REQUIRED for authentication)
# Generate a strong random string: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Vercel Postgres (REQUIRED for production deployment)
# Get these from your Vercel project dashboard: Settings -> Storage -> Connect
POSTGRES_URL=postgres://user:password@host:port/dbname
POSTGRES_PRISMA_URL=postgres://user:password@host:port/dbname?pgbouncer=true
POSTGRES_URL_NO_SSL=postgres://user:password@host:port/dbname
POSTGRES_URL_NON_POOLING=postgres://user:password@host:port/dbname
POSTGRES_USER=user
POSTGRES_HOST=host
POSTGRES_PASSWORD=password
POSTGRES_DATABASE=dbname

# Email Service (Optional)
RESEND_API_KEY=your-resend-api-key
CONTACT_EMAIL=admin@panupongwebstore.com

# Node Environment
NODE_ENV=development
