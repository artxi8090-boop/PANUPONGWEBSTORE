# Environment Variables for Panupongwebstore
# Copy this file to .env.local and fill in the values

# JWT Secret (REQUIRED for authentication)
# Generate a strong random string: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Neon Postgres Database (REQUIRED for production deployment)
# Get from: https://console.neon.tech -> Your Project -> Connection Details
DATABASE_URL=postgres://user:password@host.region.aws.neon.tech/dbname?sslmode=require

# GitHub OAuth (REQUIRED for GitHub login/signup)
# Create at: https://github.com/settings/developers -> OAuth Apps -> New OAuth App
# Homepage URL: http://localhost:3000 (dev) or https://yourdomain.com (prod)
# Authorization callback URL: http://localhost:3000/api/auth/github/callback (dev)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:3000/api/auth/github/callback

# Email Service (Optional)
RESEND_API_KEY=your-resend-api-key
CONTACT_EMAIL=admin@panupongwebstore.com

# Node Environment
NODE_ENV=development
